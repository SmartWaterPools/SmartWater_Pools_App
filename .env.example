# Core app configuration
NODE_ENV=development
PORT=5000
APP_URL=http://localhost:5000
SESSION_SECRET=replace-with-a-long-random-secret
DATABASE_URL=postgresql://username:password@localhost:5432/smartwater_pools

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional explicit callback override. If omitted, the app derives it from APP_URL.
GOOGLE_CALLBACK_URL=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Email
EMAIL_PROVIDER=smtp
EMAIL_USER=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_PASSWORD=

# Gmail integration
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# RingCentral
RINGCENTRAL_CLIENT_ID=
RINGCENTRAL_CLIENT_SECRET=
RINGCENTRAL_SERVER=https://platform.ringcentral.com

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Replit/OpenAI integrations
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=
