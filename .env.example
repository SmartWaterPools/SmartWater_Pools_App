# ─────────────────────────────────────────────
# SmartWater Pools – Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.
# ─────────────────────────────────────────────

# ── Core ──────────────────────────────────────
# Full URL of the app (no trailing slash)
# Local:  http://localhost:5000
# Replit: https://your-replit-domain.replit.app
APP_URL=http://localhost:5000

# A long random string used to sign sessions (generate with: openssl rand -hex 32)
SESSION_SECRET=change_me_to_a_long_random_string

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Set to "production" in deployed environments
NODE_ENV=development

# Port the Express server listens on (default 5000)
PORT=5000

# ── Google OAuth (login) ───────────────────────
# Create credentials at https://console.cloud.google.com
# Authorised redirect URIs must include:
#   http://localhost:5000/api/auth/google/callback   (local)
#   https://your-replit-domain.replit.app/api/auth/google/callback   (Replit)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Google Maps ───────────────────────────────
# Used for route optimisation and driving-time calculations
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Stripe (payments) ─────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── Gmail Integration ─────────────────────────
# OAuth2 credentials for sending email via Gmail
GMAIL_CLIENT_ID=your_gmail_oauth_client_id
GMAIL_CLIENT_SECRET=your_gmail_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token

# Fallback SMTP (used when Gmail OAuth is not configured)
EMAIL_PROVIDER=smtp
EMAIL_USER=your_email@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_PASSWORD=your_smtp_password

# ── RingCentral (SMS / phone) ─────────────────
RINGCENTRAL_CLIENT_ID=your_ringcentral_client_id
RINGCENTRAL_CLIENT_SECRET=your_ringcentral_client_secret
RINGCENTRAL_SERVER=https://platform.ringcentral.com

# ── OpenAI / AI Integrations ──────────────────
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
